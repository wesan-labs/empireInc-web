---
import { Globe } from "./ui/GithubGlobe";
---

<section class="relative min-h-screen bg-black overflow-hidden">
  <!-- Subtle gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-black via-neutral-950 to-black" />

  <!-- Simple grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');" />

  <!-- Content -->
  <div class="relative z-10 container mx-auto px-6 lg:px-8">
    <div class="min-h-screen flex flex-col lg:flex-row items-center justify-center gap-12 lg:gap-20 py-20">

      <!-- Left: Globe -->
      <div class="w-full lg:w-1/2 flex items-center justify-center order-2 lg:order-1">
        <div class="relative w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] lg:w-[480px] lg:h-[480px]">
          <Globe client:visible className="w-full h-full" />
        </div>
      </div>

      <!-- Right: Content -->
      <div class="w-full lg:w-1/2 order-1 lg:order-2">
        <div class="max-w-lg">

          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-neutral-800 bg-neutral-900/50 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            <span class="text-xs text-neutral-400 font-medium tracking-wide uppercase">Available on iOS & Android</span>
          </div>

          <!-- Heading -->
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white tracking-tight mb-6">
            Empire Inc.
          </h1>

          <!-- Tagline -->
          <p class="text-xl sm:text-2xl text-neutral-300 font-light mb-4">
            Build Your Business Empire
          </p>

          <!-- Description -->
          <p class="text-base text-neutral-500 leading-relaxed mb-10 max-w-md">
            From zero to billionaire. Master markets, compete globally, and earn while you sleep.
          </p>

          <!-- Stats -->
          <div class="flex gap-10 mb-10">
            <div>
              <div class="text-2xl font-semibold text-white">100K+</div>
              <div class="text-sm text-neutral-500">Players</div>
            </div>
            <div>
              <div class="text-2xl font-semibold text-white flex items-center gap-1">
                4.9
                <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              </div>
              <div class="text-sm text-neutral-500">Rating</div>
            </div>
            <div>
              <div class="text-2xl font-semibold text-white">#1</div>
              <div class="text-sm text-neutral-500">Business Sim</div>
            </div>
          </div>

          <!-- Download Section -->
          <div class="p-6 rounded-2xl bg-neutral-900/50 border border-neutral-800/50 backdrop-blur-sm">

            <!-- Store Buttons -->
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
              <!-- App Store -->
              <a
                href="https://apps.apple.com/us/app/empire-inc/id6757396694"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex-1 inline-flex items-center justify-center gap-3 px-5 py-3.5 bg-white text-black rounded-xl hover:bg-neutral-50 transition-all hover:scale-[1.02] hover:shadow-lg hover:shadow-white/10"
              >
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
                <div class="text-left">
                  <div class="text-[10px] leading-none opacity-60 font-medium">Download on the</div>
                  <div class="text-lg font-semibold leading-tight">App Store</div>
                </div>
              </a>

              <!-- Google Play -->
              <a
                href="#"
                class="group flex-1 inline-flex items-center justify-center gap-3 px-5 py-3.5 bg-white text-black rounded-xl hover:bg-neutral-50 transition-all hover:scale-[1.02] hover:shadow-lg hover:shadow-white/10"
              >
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/>
                </svg>
                <div class="text-left">
                  <div class="text-[10px] leading-none opacity-60 font-medium">GET IT ON</div>
                  <div class="text-lg font-semibold leading-tight">Google Play</div>
                </div>
              </a>
            </div>

            <!-- Divider -->
            <div class="flex items-center gap-4 mb-6">
              <div class="flex-1 h-px bg-neutral-800"></div>
              <span class="text-xs text-neutral-600 uppercase tracking-wider">or scan to download</span>
              <div class="flex-1 h-px bg-neutral-800"></div>
            </div>

            <!-- QR Codes -->
            <div class="flex justify-center gap-8">
              <!-- iOS QR -->
              <div class="group text-center">
                <a href="https://apps.apple.com/us/app/empire-inc/id6757396694" target="_blank" rel="noopener noreferrer" class="relative block w-28 h-28 bg-white rounded-xl p-2 mb-3 transition-transform group-hover:scale-105">
                  <!-- Platform icon badge -->
                  <div class="absolute -top-2 -right-2 w-7 h-7 bg-black rounded-full flex items-center justify-center shadow-lg z-10">
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                    </svg>
