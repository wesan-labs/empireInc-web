---
import { Globe } from "./ui/GithubGlobe";
import { BackgroundBeams } from "./ui/BackgroundBeams";
import { TextGenerateEffect } from "./ui/TextGenerateEffect";
import { Meteors } from "./ui/Meteors";
import { Spotlight } from "./ui/Spotlight";
---

<section class="relative min-h-screen overflow-hidden bg-slate-950">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950" />

  <!-- Spotlight Effect -->
  <Spotlight
    client:load
    className="-top-40 left-0 md:left-60 md:-top-20"
    fill="rgba(59, 130, 246, 0.15)"
  />

  <!-- Background Beams -->
  <BackgroundBeams client:load className="z-0" />

  <!-- Meteors -->
  <Meteors client:load number={15} className="z-0" />

  <!-- Grid Pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_110%)] z-0" />

  <!-- Main Content -->
  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="min-h-screen flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-16 py-20">

      <!-- Left Side: Globe -->
      <div class="w-full lg:w-1/2 flex items-center justify-center order-2 lg:order-1">
        <div class="relative">
          <Globe client:visible className="w-[350px] h-[350px] sm:w-[450px] sm:h-[450px] lg:w-[550px] lg:h-[550px]" />

          <!-- Glow rings -->
          <div class="absolute inset-0 rounded-full bg-gradient-to-r from-blue-500/20 to-purple-500/20 blur-3xl -z-10 scale-110" />
        </div>
      </div>

      <!-- Right Side: Content -->
      <div class="w-full lg:w-1/2 flex items-center justify-center lg:justify-start order-1 lg:order-2">
        <div class="relative max-w-xl w-full">

          <!-- Glassmorphism Card -->
          <div class="glass-card p-8 sm:p-10 lg:p-12 rounded-3xl animate-fade-in">

            <!-- Badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/30 mb-6 backdrop-blur-sm">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
              </span>
              <span class="text-sm text-blue-400 font-medium">Now Available on App Store</span>
            </div>

            <!-- Heading -->
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black mb-4 leading-tight">
              <span class="bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent bg-[length:200%_auto] animate-gradient-x">
                Empire Inc.
              </span>
            </h1>

            <!-- Tagline with Text Generate Effect -->
            <div class="text-xl sm:text-2xl lg:text-3xl text-white font-semibold mb-6 min-h-[2.5rem]">
              <TextGenerateEffect
                client:visible
                words="Build Your Business Empire"
                className="text-white"
                duration={0.3}
              />
            </div>

            <!-- Description -->
            <p class="text-base sm:text-lg text-slate-300 mb-8 leading-relaxed">
              From zero to billionaire. Master markets, compete globally, and earn while you sleep.
              <span class="text-blue-400 font-medium"> 6 industries</span>,
              <span class="text-purple-400 font-medium"> unlimited potential</span>.
            </p>

            <!-- Stats Row -->
            <div class="flex flex-wrap gap-8 mb-8">
              <div class="stat-item">
                <div class="text-3xl font-bold bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
                  100K+
                </div>
                <div class="text-sm text-slate-400">Active Players</div>
              </div>

              <div class="stat-item">
                <div class="text-3xl font-bold text-white flex items-center gap-1">
                  4.9
                  <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                </div>
                <div class="text-sm text-slate-400">App Store Rating</div>
              </div>

              <div class="stat-item">
                <div class="text-3xl font-bold text-white">#1</div>
                <div class="text-sm text-slate-400">Business Sim</div>
              </div>
            </div>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="#"
                class="group relative inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl font-bold text-white overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(59,130,246,0.4)]"
              >
                <span class="absolute inset-0 bg-gradient-to-r from-blue-400 to-purple-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                <span class="relative flex items-center gap-2">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                  </svg>
                  Download for iOS
                </span>

                <!-- Shimmer effect -->
                <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover:translate-x-full transition-transform duration-1000" />
              </a>

              <a
                href="#"
                class="group relative inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-bold text-white border-2 border-slate-600 hover:border-blue-500 transition-all duration-300 hover:bg-blue-500/10"
              >
                <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Watch Trailer
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <span class="text-sm text-slate-500">Scroll to explore</span>
    <div class="w-6 h-10 border-2 border-slate-600 rounded-full flex justify-center">
      <div class="w-1.5 h-3 bg-slate-400 rounded-full mt-2 animate-bounce" />
    </div>
  </div>
</section>

<style>
  .glass-card {
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }

  @keyframes gradient-x {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .animate-gradient-x {
    animation: gradient-x 3s ease infinite;
  }

  .stat-item {
    position: relative;
    padding-left: 0;
  }

  .stat-item::before {
    content: '';
    position: absolute;
    left: -16px;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 40px;
    background: linear-gradient(to bottom, #3b82f6, #8b5cf6);
    border-radius: 2px;
    display: none;
  }

  .stat-item:not(:first-child)::before {
    display: block;
  }
</style>
